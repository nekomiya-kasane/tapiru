# clangd configuration — delegates to workspace compile_commands.json

CompileFlags:
  CompilationDatabase: ../build/relwithdebinfo-coca-toolchain-win-x64

Diagnostics:
  UnusedIncludes: Strict
  MissingIncludes: Strict
  ClangTidy:
    Add:
      - bugprone-*
      - performance-*
      - modernize-*
      - readability-*
      - cppcoreguidelines-*
      - clang-analyzer-*
      - misc-*
      - cert-*
    Remove:
      - modernize-use-trailing-return-type
      - readability-implicit-bool-conversion
      - readability-identifier-length
      - misc-non-private-member-variables-in-classes
      - cppcoreguidelines-owning-memory
      - cppcoreguidelines-non-private-member-variables-in-classes
      - bugprone-easily-swappable-parameters

InlayHints:
  Enabled: Yes
  ParameterNames: Yes
  DeducedTypes: Yes

Hover:
  ShowAKA: Yes
